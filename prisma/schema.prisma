generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  username  String    @unique
  email     String    @unique
  password  String    @db.Text
  createdAt DateTime  @default(now()) 
  workouts  Workout[]

  @@map("users")
}

model Workout {
  id         String      @id @default(uuid()) @db.Uuid
  excercises Exercise[]
  user       User       @relation(fields: [userId], references: [id])
  userId     String     @db.Uuid

  @@map("workouts")
}

model Exercise {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String
  category    Category
  workout     Workout[]

  @@map("exercises")
}

enum Category {
  Cardio
  Strength
  Flexibility
}
